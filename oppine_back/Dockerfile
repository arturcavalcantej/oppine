FROM python:3.11-slim

ARG ENVIRONMENT
ARG SECRET_KEY
ARG DATABASE_URL
ARG GEMINI_API_KEY
ARG OPENAI_API_KEY
ARG USE_S3_STORAGE
ARG AWS_ACCESS_KEY_ID
ARG AWS_SECRET_ACCESS_KEY
ARG AWS_S3_BUCKET_NAME
ARG ALGORITHM
ARG AWS_REGION
ARG CORS_ORIGINS
ARG APIFY_API_TOKEN
ARG INSTAGRAM_SCRAPE_DAILY_LIMIT_PER_USER
ARG INSTAGRAM_CACHE_EXPIRY_DAYS
ARG OPENROUTER_API_KEY
ARG JWT_SECRET_KEY
ARG ANGULAR_HUB_ENABLED
ARG ANGULAR_HUB_API_URL
ARG ANGULAR_HUB_SAAS_SLUG
ARG ANGULAR_HUB_SAAS_ID
ARG ANGULAR_HUB_API_KEY
ARG ANGULAR_HUB_JWT_SECRET
ARG ANGULAR_HUB_WEBHOOK_SECRET

# Set environment variables
ENV ENVIRONMENT=${ENVIRONMENT}
ENV SECRET_KEY=${SECRET_KEY}
ENV DATABASE_URL=${DATABASE_URL}
ENV GEMINI_API_KEY=${GEMINI_API_KEY}
ENV OPENAI_API_KEY=${OPENAI_API_KEY}
ENV USE_S3_STORAGE=${USE_S3_STORAGE}
ENV AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
ENV AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
ENV AWS_S3_BUCKET_NAME=${AWS_S3_BUCKET_NAME}
ENV ALGORITHM=${ALGORITHM}
ENV AWS_REGION=${AWS_REGION}
ENV CORS_ORIGINS=${CORS_ORIGINS}
ENV APIFY_API_TOKEN=${APIFY_API_TOKEN}
ENV INSTAGRAM_SCRAPE_DAILY_LIMIT_PER_USER=${INSTAGRAM_SCRAPE_DAILY_LIMIT_PER_USER}
ENV INSTAGRAM_CACHE_EXPIRY_DAYS=${INSTAGRAM_CACHE_EXPIRY_DAYS}
ENV OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
ENV JWT_SECRET_KEY=${JWT_SECRET_KEY}
ENV ANGULAR_HUB_ENABLED=${ANGULAR_HUB_ENABLED}
ENV ANGULAR_HUB_API_URL=${ANGULAR_HUB_API_URL}
ENV ANGULAR_HUB_SAAS_SLUG=${ANGULAR_HUB_SAAS_SLUG}
ENV ANGULAR_HUB_SAAS_ID=${ANGULAR_HUB_SAAS_ID}
ENV ANGULAR_HUB_API_KEY=${ANGULAR_HUB_API_KEY}
ENV ANGULAR_HUB_JWT_SECRET=${ANGULAR_HUB_JWT_SECRET}
ENV ANGULAR_HUB_WEBHOOK_SECRET=${ANGULAR_HUB_WEBHOOK_SECRET}


WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# Create directory for SQLite database
RUN mkdir -p /app/data

# Expose port
EXPOSE 8000

# Run the application
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "5"]