# =============================================================================
# Oppine Backend Configuration
# =============================================================================

# Database
DATABASE_URL=sqlite:///./oppine.db

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# CORS Origins (comma-separated or JSON array)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Backend URL
BACKEND_URL=http://localhost:8000

# =============================================================================
# Angular Hub Integration (SSO & Payments)
# =============================================================================
ANGULAR_HUB_ENABLED=true
ANGULAR_HUB_API_URL=https://api.angularhub.com.br
ANGULAR_HUB_SAAS_SLUG=oppine
ANGULAR_HUB_SAAS_ID=your-saas-uuid
ANGULAR_HUB_API_KEY=your-api-key
ANGULAR_HUB_JWT_SECRET=your-jwt-secret
ANGULAR_HUB_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# WhatsApp Integration (Evolution API)
# =============================================================================
# Provider: evolution (producao) ou mock (desenvolvimento)
WHATSAPP_PROVIDER=evolution

# Evolution API - https://github.com/EvolutionAPI/evolution-api
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-api-key
# Nota: Cada negocio (Business) tem seu proprio whatsapp_instance_id

# =============================================================================
# App Configuration
# =============================================================================
APP_DOMAIN=https://app.oppine.com.br

# Sentry (opcional - monitoramento de erros)
SENTRY_DSN=

# =============================================================================
# Storage (for testimonial audio, etc.)
# =============================================================================
STORAGE_MODE=local
LOCAL_MEDIA_PATH=media

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_REGION=us-east-1

# =============================================================================
# Google Business Profile Integration (Reviews sync)
# =============================================================================
GOOGLE_INTEGRATION_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.oppine.com.br/dashboard/settings?tab=integrations
GOOGLE_TOKEN_ENCRYPTION_KEY=  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# =============================================================================
# Stripe (optional - payments via Angular Hub)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
